{
  "name": "fable-orchestrator",
  "displayName": "Fable Orchestrator",
  "description": "Multi-account dispatch for the Claude Code extension: your main session (Fable) fans tasks out to worker Claude accounts running Opus/Sonnet via an MCP dispatch tool.",
  "version": "0.3.1",
  "publisher": "toragonite",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Toragonite/fable-orchestrator.git"
  },
  "keywords": [
    "claude",
    "claude-code",
    "mcp",
    "multi-account",
    "orchestration",
    "agent"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "fableOrchestrator",
          "title": "Fable Orchestrator",
          "icon": "$(organization)"
        }
      ]
    },
    "views": {
      "fableOrchestrator": [
        {
          "id": "fableOrchestrator.workers",
          "name": "Worker Accounts",
          "icon": "$(server-process)"
        },
        {
          "id": "fableOrchestrator.tasks",
          "name": "Dispatched Tasks",
          "icon": "$(checklist)"
        }
      ]
    },
    "commands": [
      {
        "command": "fableOrchestrator.addWorker",
        "title": "Add Worker Account",
        "category": "Fable Orchestrator",
        "icon": "$(add)"
      },
      {
        "command": "fableOrchestrator.importWorkers",
        "title": "Import Existing Claude Config Directories",
        "category": "Fable Orchestrator",
        "icon": "$(cloud-download)"
      },
      {
        "command": "fableOrchestrator.removeWorker",
        "title": "Remove Worker Account",
        "category": "Fable Orchestrator",
        "icon": "$(trash)"
      },
      {
        "command": "fableOrchestrator.loginWorker",
        "title": "Re-login Worker Account (opens terminal to sign in)",
        "category": "Fable Orchestrator",
        "icon": "$(sign-in)"
      },
      {
        "command": "fableOrchestrator.openWorkerSession",
        "title": "Open Worker Session in Terminal (watch & steer this account)",
        "category": "Fable Orchestrator",
        "icon": "$(terminal)"
      },
      {
        "command": "fableOrchestrator.installMcp",
        "title": "Register Dispatch MCP Server in This Workspace",
        "category": "Fable Orchestrator",
        "icon": "$(plug)"
      },
      {
        "command": "fableOrchestrator.showTaskOutput",
        "title": "Show Task Output",
        "category": "Fable Orchestrator"
      },
      {
        "command": "fableOrchestrator.clearTasks",
        "title": "Clear Task History",
        "category": "Fable Orchestrator",
        "icon": "$(clear-all)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "fableOrchestrator.addWorker",
          "when": "view == fableOrchestrator.workers",
          "group": "navigation@1"
        },
        {
          "command": "fableOrchestrator.importWorkers",
          "when": "view == fableOrchestrator.workers",
          "group": "navigation@2"
        },
        {
          "command": "fableOrchestrator.installMcp",
          "when": "view == fableOrchestrator.workers",
          "group": "navigation@3"
        },
        {
          "command": "fableOrchestrator.clearTasks",
          "when": "view == fableOrchestrator.tasks",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "fableOrchestrator.openWorkerSession",
          "when": "view == fableOrchestrator.workers && viewItem == worker",
          "group": "inline"
        },
        {
          "command": "fableOrchestrator.loginWorker",
          "when": "view == fableOrchestrator.workers && viewItem == worker",
          "group": "1_manage@1"
        },
        {
          "command": "fableOrchestrator.removeWorker",
          "when": "view == fableOrchestrator.workers && viewItem == worker",
          "group": "1_manage@2"
        }
      ]
    },
    "walkthroughs": [
      {
        "id": "fableOrchestrator.gettingStarted",
        "title": "Multi-account dispatch for Claude Code",
        "description": "Fan work out from your Claude Code panel to worker Claude accounts running Opus/Sonnet.",
        "steps": [
          {
            "id": "addWorker",
            "title": "Add a worker account",
            "description": "Create a config directory for another Claude account and sign in once.\n[Add Worker Account](command:fableOrchestrator.addWorker)\n[Import Existing Directories](command:fableOrchestrator.importWorkers)",
            "media": {
              "markdown": "media/walkthrough/add-worker.md"
            },
            "completionEvents": [
              "onCommand:fableOrchestrator.addWorker",
              "onCommand:fableOrchestrator.importWorkers"
            ]
          },
          {
            "id": "registerMcp",
            "title": "Register the dispatch MCP server",
            "description": "Give your Claude Code session the dispatch_task tool in this workspace.\n[Register MCP Server](command:fableOrchestrator.installMcp)",
            "media": {
              "markdown": "media/walkthrough/register-mcp.md"
            },
            "completionEvents": [
              "onCommand:fableOrchestrator.installMcp"
            ]
          },
          {
            "id": "useDispatch",
            "title": "Dispatch from your Claude Code panel",
            "description": "Restart the Claude Code session, approve the MCP server, and ask it to fan out work.",
            "media": {
              "markdown": "media/walkthrough/use-dispatch.md"
            }
          }
        ]
      }
    ],
    "configuration": {
      "title": "Fable Orchestrator",
      "properties": {
        "fableOrchestrator.workerPermissionMode": {
          "type": "string",
          "default": "acceptEdits",
          "enum": [
            "default",
            "acceptEdits",
            "plan",
            "bypassPermissions"
          ],
          "description": "--permission-mode for dispatched (background) worker sessions. Background workers cannot answer permission prompts, so 'default' will stall on any edit."
        },
        "fableOrchestrator.claudePath": {
          "type": "string",
          "default": "claude",
          "description": "Path to the Claude Code CLI executable."
        },
        "fableOrchestrator.quotaCooldownMinutes": {
          "type": "number",
          "default": 30,
          "description": "Minutes a worker account sits out after a quota/rate-limit error before dispatches are routed to it again."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./ && npm run bundle-server",
    "bundle-server": "esbuild src/mcp/server.ts --bundle --platform=node --target=node18 --outfile=out/mcp/server.js",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.6.0"
  }
}
