{
  "name": "claude-code-orchestrator",
  "displayName": "Claude Code Orchestrator",
  "description": "Unofficial multi-account orchestration for Claude Code: your main session designs and verifies while worker Claude accounts implement in parallel via MCP dispatch tools, with quota-aware failover and per-account usage tracking.",
  "version": "0.7.0",
  "publisher": "toragonite",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Toragonite/claude-code-orchestrator.git"
  },
  "keywords": [
    "claude",
    "claude-code",
    "mcp",
    "multi-account",
    "orchestration",
    "agent"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeCodeOrchestrator",
          "title": "Claude Code Orchestrator",
          "icon": "$(organization)"
        }
      ]
    },
    "views": {
      "claudeCodeOrchestrator": [
        {
          "id": "claudeCodeOrchestrator.workers",
          "name": "Worker Accounts",
          "icon": "$(server-process)"
        },
        {
          "id": "claudeCodeOrchestrator.tasks",
          "name": "Dispatched Tasks",
          "icon": "$(checklist)"
        }
      ]
    },
    "commands": [
      {
        "command": "claudeCodeOrchestrator.addWorker",
        "title": "Add Worker Account",
        "category": "Claude Code Orchestrator",
        "icon": "$(add)"
      },
      {
        "command": "claudeCodeOrchestrator.importWorkers",
        "title": "Import Existing Claude Config Directories",
        "category": "Claude Code Orchestrator",
        "icon": "$(cloud-download)"
      },
      {
        "command": "claudeCodeOrchestrator.removeWorker",
        "title": "Remove Worker Account",
        "category": "Claude Code Orchestrator",
        "icon": "$(trash)"
      },
      {
        "command": "claudeCodeOrchestrator.loginWorker",
        "title": "Re-login Worker Account (opens terminal to sign in)",
        "category": "Claude Code Orchestrator",
        "icon": "$(sign-in)"
      },
      {
        "command": "claudeCodeOrchestrator.openWorkerSession",
        "title": "Open Worker Session in Terminal (watch & steer this account)",
        "category": "Claude Code Orchestrator",
        "icon": "$(terminal)"
      },
      {
        "command": "claudeCodeOrchestrator.installMcp",
        "title": "Register Dispatch MCP Server in This Workspace",
        "category": "Claude Code Orchestrator",
        "icon": "$(plug)"
      },
      {
        "command": "claudeCodeOrchestrator.showTaskOutput",
        "title": "Show Task Output",
        "category": "Claude Code Orchestrator"
      },
      {
        "command": "claudeCodeOrchestrator.clearTasks",
        "title": "Clear Task History",
        "category": "Claude Code Orchestrator",
        "icon": "$(clear-all)"
      },
      {
        "command": "claudeCodeOrchestrator.togglePreferred",
        "title": "Toggle Preferred Worker (same account as main — favored when idle)",
        "category": "Claude Code Orchestrator",
        "icon": "$(star)"
      },
      {
        "command": "claudeCodeOrchestrator.toggleTaskScope",
        "title": "Toggle Task Scope (This Workspace / All)",
        "category": "Claude Code Orchestrator",
        "icon": "$(filter)"
      },
      {
        "command": "claudeCodeOrchestrator.openDashboard",
        "title": "Open Orchestrator Dashboard",
        "category": "Claude Code Orchestrator",
        "icon": "$(dashboard)"
      },
      {
        "command": "claudeCodeOrchestrator.addDispatchPolicy",
        "title": "Add Dispatch Policy to CLAUDE.md",
        "category": "Claude Code Orchestrator",
        "icon": "$(book)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "claudeCodeOrchestrator.addWorker",
          "when": "view == claudeCodeOrchestrator.workers",
          "group": "navigation@1"
        },
        {
          "command": "claudeCodeOrchestrator.importWorkers",
          "when": "view == claudeCodeOrchestrator.workers",
          "group": "navigation@2"
        },
        {
          "command": "claudeCodeOrchestrator.installMcp",
          "when": "view == claudeCodeOrchestrator.workers",
          "group": "navigation@3"
        },
        {
          "command": "claudeCodeOrchestrator.toggleTaskScope",
          "when": "view == claudeCodeOrchestrator.tasks",
          "group": "navigation@1"
        },
        {
          "command": "claudeCodeOrchestrator.openDashboard",
          "when": "view == claudeCodeOrchestrator.tasks",
          "group": "navigation@2"
        },
        {
          "command": "claudeCodeOrchestrator.clearTasks",
          "when": "view == claudeCodeOrchestrator.tasks",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "claudeCodeOrchestrator.openWorkerSession",
          "when": "view == claudeCodeOrchestrator.workers && viewItem == worker",
          "group": "inline"
        },
        {
          "command": "claudeCodeOrchestrator.togglePreferred",
          "when": "view == claudeCodeOrchestrator.workers && viewItem == worker",
          "group": "1_manage@0"
        },
        {
          "command": "claudeCodeOrchestrator.loginWorker",
          "when": "view == claudeCodeOrchestrator.workers && viewItem == worker",
          "group": "1_manage@1"
        },
        {
          "command": "claudeCodeOrchestrator.removeWorker",
          "when": "view == claudeCodeOrchestrator.workers && viewItem == worker",
          "group": "1_manage@2"
        }
      ]
    },
    "walkthroughs": [
      {
        "id": "claudeCodeOrchestrator.gettingStarted",
        "title": "Multi-account dispatch for Claude Code",
        "description": "Fan work out from your Claude Code panel to worker Claude accounts running Opus/Sonnet.",
        "steps": [
          {
            "id": "addWorker",
            "title": "Add a worker account",
            "description": "Create a config directory for another Claude account and sign in once.\n[Add Worker Account](command:claudeCodeOrchestrator.addWorker)\n[Import Existing Directories](command:claudeCodeOrchestrator.importWorkers)",
            "media": {
              "markdown": "media/walkthrough/add-worker.md"
            },
            "completionEvents": [
              "onCommand:claudeCodeOrchestrator.addWorker",
              "onCommand:claudeCodeOrchestrator.importWorkers"
            ]
          },
          {
            "id": "registerMcp",
            "title": "Register the dispatch MCP server",
            "description": "Give your Claude Code session the dispatch_task tool in this workspace.\n[Register MCP Server](command:claudeCodeOrchestrator.installMcp)",
            "media": {
              "markdown": "media/walkthrough/register-mcp.md"
            },
            "completionEvents": [
              "onCommand:claudeCodeOrchestrator.installMcp"
            ]
          },
          {
            "id": "useDispatch",
            "title": "Dispatch from your Claude Code panel",
            "description": "Restart the Claude Code session, approve the MCP server, and ask it to fan out work.",
            "media": {
              "markdown": "media/walkthrough/use-dispatch.md"
            }
          }
        ]
      }
    ],
    "configuration": {
      "title": "Claude Code Orchestrator",
      "properties": {
        "claudeCodeOrchestrator.workerPermissionMode": {
          "type": "string",
          "default": "acceptEdits",
          "enum": [
            "default",
            "acceptEdits",
            "plan",
            "bypassPermissions"
          ],
          "description": "--permission-mode for dispatched (background) worker sessions. Background workers cannot answer permission prompts, so 'default' will stall on any edit."
        },
        "claudeCodeOrchestrator.claudePath": {
          "type": "string",
          "default": "claude",
          "description": "Path to the Claude Code CLI executable."
        },
        "claudeCodeOrchestrator.quotaCooldownMinutes": {
          "type": "number",
          "default": 30,
          "description": "Minutes a worker account sits out after a quota/rate-limit error before dispatches are routed to it again."
        },
        "claudeCodeOrchestrator.frontierWorkerDispatch": {
          "type": "string",
          "default": "block",
          "enum": [
            "block",
            "allow"
          ],
          "enumDescriptions": [
            "Reject worker dispatches to frontier models (claude-fable-5) with a fall-back hint — recommended when Fable bills per use instead of drawing from the subscription quota.",
            "Allow worker dispatches to frontier models. Enable only if you accept the cost (separate quota or pay-per-use billing, depending on the plan)."
          ],
          "description": "Billing guard for frontier worker models (claude-fable-5). 'block' makes the dispatch server reject them and steer the orchestrator to claude-opus-4-8 + ultrathink."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./ && npm run bundle-server",
    "bundle-server": "esbuild src/mcp/server.ts --bundle --platform=node --target=node18 --outfile=out/mcp/server.js",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.6.0"
  },
  "galleryBanner": {
    "color": "#1b1b2f",
    "theme": "dark"
  }
}
